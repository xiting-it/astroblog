---
import NextLayout from '../../layouts/NextLayout.astro';
import PostCardNext from '../../components/PostCardNext.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 10;
  const allPosts = await getCollection('posts');
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  // 生成分页路由（从第2页开始，第1页是首页）
  const paths = [];
  for (let i = 2; i <= totalPages; i++) {
    paths.push({
      params: { page: i.toString() },
    });
  }

  return paths;
}

// 每页显示的文章数（与首页保持一致）
const POSTS_PER_PAGE = 10;

// 获取所有文章并按发布时间排序
const allPosts = (await getCollection('posts')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 计算总页数
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

// 获取当前页码
const pageParam = Astro.params.page;
const currentPage = parseInt(pageParam || '1') || 1;

// 如果页码超出范围，重定向到首页
if (currentPage < 1 || currentPage > totalPages) {
  return Astro.redirect('/');
}

// 获取当前页的文章
const start = (currentPage - 1) * POSTS_PER_PAGE;
const end = start + POSTS_PER_PAGE;
const posts = allPosts.slice(start, end);

// 生成页码
const pages = [];
for (let i = 1; i <= totalPages; i++) {
  pages.push(i);
}
---

<NextLayout title={`第 ${currentPage} 页`}>
  <section id="posts" class="posts-expand">
    {posts.length === 0 ? (
      <div style="text-align: center; color: #999; padding: 40px;">
        暂无文章
      </div>
    ) : (
      posts.map((post) => (
        <PostCardNext
          title={post.data.title}
          url={`/blog/${post.id.replace('.md', '')}/`}
          date={new Date(post.data.pubDate).toLocaleDateString('zh-CN')}
          excerpt={post.data.description}
          categories={post.data.tags?.map(tag => ({ name: tag, url: `/tags/${tag}` })) || []}
          backgroundImage={post.data.backgroundImage}
        />
      ))
    )}
  </section>

  {totalPages > 1 && (
    <nav class="pagination">
      {pages.map((page) => (
        page === currentPage ? (
          <span class="page-number current">{page}</span>
        ) : page === 1 ? (
          <a class="page-number" href="/">{page}</a>
        ) : (
          <a class="page-number" href={`/page/${page}`}>{page}</a>
        )
      ))}
    </nav>
  )}
</NextLayout>

<style>
  .posts-expand {
    max-width: 800px;
    margin: 0 auto;
    padding: 20px 20px 40px;
  }

  .pagination {
    margin: 60px 0;
    text-align: center;
  }

  .page-number,
  .extend {
    display: inline-block;
    margin: 0 5px;
    padding: 10px 15px;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 4px;
    text-decoration: none;
    color: #333;
    transition: all 0.3s;
  }

  .page-number.current {
    background: #222;
    color: #fff;
    border-color: #222;
  }

  .page-number:hover,
  .extend:hover {
    background: #f5f5f5;
  }
</style>
