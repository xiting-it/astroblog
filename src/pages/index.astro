---
import NextLayout from '../layouts/NextLayout.astro';
import PostCardNext from '../components/PostCardNext.astro';

// Fetch homepage settings and posts from admin API
let homepageSettings = { postsPerPage: 10, pinnedPostSlug: null, pinnedPostTitle: null };
let postsData = { posts: [], pagination: { totalPages: 0 } };
try {
  // First fetch homepage settings
  const settingsRes = await fetch('http://localhost:3002/api/homepage/settings');
  if (settingsRes.ok) {
    homepageSettings = await settingsRes.json();
  }

  // Then fetch posts with the configured postsPerPage
  const postsRes = await fetch('http://localhost:3002/api/posts?page=1&limit=' + (homepageSettings.postsPerPage || 10));
  if (postsRes.ok) {
    postsData = await postsRes.json();
  }
} catch (e) {
  console.warn('Failed to fetch data from API, using defaults');
}

const { postsPerPage, pinnedPostSlug } = homepageSettings;
const { posts, pagination } = postsData;
const totalPages = pagination.totalPages;

// 当前页码（主页是第1页）
const currentPage = 1;

// 生成页码
const pages = [];
for (let i = 1; i <= totalPages; i++) {
  pages.push(i);
}
---

<NextLayout>
  <section id="posts" class="posts-expand">
    {posts.length === 0 ? (
      <div style="text-align: center; color: #999; padding: 40px;">
        暂无文章
      </div>
    ) : (
      posts.map((post) => (
        <PostCardNext
          title={post.title}
          url={`/blog/${post.slug}/`}
          date={new Date(post.pubDate).toLocaleDateString('zh-CN')}
          updatedDate={post.updatedDate ? new Date(post.updatedDate).toLocaleDateString('zh-CN') : undefined}
          wordCount={post.wordCount}
          categories={post.categories || []}
          tags={post.tags?.map(tag => ({ name: tag, url: `/tags/${tag}` })) || []}
          excerpt={post.excerpt}
          backgroundImage={post.backgroundImage}
          isPinned={post.pinnedPost}
          showFullMeta={false}
        />
      ))
    )}
  </section>

  {totalPages > 1 && (
    <nav class="pagination">
      {pages.map((page) => (
        page === currentPage ? (
          <span class="page-number current">{page}</span>
        ) : (
          <a class="page-number" href={`/page/${page}`}>{page}</a>
        )
      ))}
    </nav>
  )}
</NextLayout>

<style>
  .posts-expand {
    max-width: 880px;
    margin: 0 auto;
    padding: 20px 26px 40px;
  }

  .pagination {
    margin: 60px 0;
    text-align: center;
  }

  .page-number,
  .extend {
    display: inline-block;
    margin: 0 5px;
    padding: 10px 15px;
    background: #fff;
    border: 1px solid #eee;
    border-radius: 4px;
    text-decoration: none;
    color: #333;
    transition: all 0.3s;
  }

  .page-number.current {
    background: #222;
    color: #fff;
    border-color: #222;
  }

  .page-number:hover,
  .extend:hover {
    background: #f5f5f5;
  }
</style>
