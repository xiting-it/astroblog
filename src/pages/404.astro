---
import NextLayout from '../layouts/NextLayout.astro';

const currentPath = Astro.url.pathname;
---

<NextLayout title="404 - Not Found">
  <section class="error-page">
    <div class="error-container">
      <h1 class="error-code">404</h1>
      <p class="error-message">Not Found</p>
      <p class="error-path">Path: {currentPath}</p>
      <a href="/" class="back-link">返回首页</a>
    </div>
  </section>
</NextLayout>

<style>
  .error-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .error-container {
    text-align: center;
    background: var(--bg-card);
    padding: 60px 40px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    max-width: 560px;
    width: 100%;
  }

  .error-code {
    font-size: 120px;
    font-weight: 700;
    margin: 0;
    line-height: 1;
    letter-spacing: 4px;
    color: var(--color-accent);
  }

  .error-message {
    font-size: 32px;
    font-weight: 600;
    margin: 20px 0 30px;
    color: var(--text-primary);
  }

  .error-path {
    font-size: 14px;
    margin: 0 0 30px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    background: var(--bg-gray-6, var(--bg-inline-code));
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    display: inline-block;
    word-break: break-all;
  }

  .back-link {
    display: inline-block;
    color: var(--color-accent);
    text-decoration: none;
    font-size: 16px;
    padding: 10px 24px;
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-sm);
    transition: all 0.2s;
  }

  .back-link:hover {
    background: var(--color-accent);
    color: #fff;
  }

  @media (max-width: 767px) {
    .error-code {
      font-size: 80px;
      letter-spacing: 2px;
    }

    .error-message {
      font-size: 24px;
      margin: 15px 0 20px;
    }
  }
</style>
