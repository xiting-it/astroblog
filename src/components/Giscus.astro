---
/**
 * Giscus 评论组件
 *
 * 配置来源：site-config.yaml 的 comment 字段
 * 仓库：xiting-it/commentgiscus
 */
import { loadConfig } from '../lib/config';

interface Props {
  /** 当前页面路径，用作 Giscus 的 pathname 映射 */
  path?: string;
}

const { path } = Astro.props;
const commentConfig = loadConfig().comment;
const giscus = commentConfig.giscus;
const isEnabled = commentConfig?.enabled && !!giscus?.repo && !!giscus?.repoId;
---

{isEnabled ? (
  <div class="giscus-container" data-path={path || ''}></div>
) : (
  <p style="text-align:center; color:#999; padding:20px 0;">
    评论系统未配置，请在 <code>site-config.yaml</code> 中设置 <code>comment.giscus</code>。
  </p>
)}

<script is:inline define:vars={{ giscus, currentPath: path || Astro.url.pathname }}>
  (function () {
    if (!giscus || !giscus.repo || !giscus.repoId) return;

    const container = document.querySelector('.giscus-container');
    if (!container) return;

    // 设置 giscus theme based on html.dark class (auto switch)
    function getTheme() {
      return document.documentElement.classList.contains('dark')
        ? giscus.darkTheme || 'dark_tritanopia'
        : giscus.theme || 'light_tritanopia';
    }

    function mountGiscus(theme) {
      // 清掉旧的（主题切换时重建 iframe）
      container.innerHTML = '';

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', giscus.repo);
      script.setAttribute('data-repo-id', giscus.repoId);
      script.setAttribute('data-category', giscus.category || 'Announcements');
      script.setAttribute('data-category-id', giscus.categoryId || '');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', giscus.reactionsEnabled ? '1' : '0');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', giscus.inputPosition || 'bottom');
      script.setAttribute('data-theme', theme);
      script.setAttribute('data-lang', giscus.lang || 'zh-CN');
      script.setAttribute('data-loading', 'lazy');
      script.crossOrigin = 'anonymous';
      script.async = true;
      container.appendChild(script);
    }

    // 懒加载：评论区进入视口时才挂载
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              mountGiscus(getTheme());
              observer.disconnect();
            }
          });
        },
        { rootMargin: '300px' }
      );
      observer.observe(container);
    } else {
      mountGiscus(getTheme());
    }

    // 暗色模式切换时同步 Giscus 主题
    window.__updateGiscusTheme = function () {
      const iframe = container.querySelector('iframe.giscus-frame');
      if (!iframe) return;
      iframe.contentWindow.postMessage(
        { giscus: { setConfig: { theme: getTheme() } } },
        'https://giscus.app'
      );
    };

    // 监听 dark class 变化
    const observer = new MutationObserver(function () {
      window.__updateGiscusTheme();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  })();
</script>

<style>
  .giscus-container {
    /* 容器约束交给父级 .comment-block */
  }

  :global(.giscus-frame) {
    margin: 0 !important;
    padding: 0 !important;
    border-radius: 8px;
  }

  :global(.giscus-container iframe) {
    border: none;
  }
</style>
