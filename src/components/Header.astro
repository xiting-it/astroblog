---
const { currentPath = '/' } = Astro.props;

const navItems = [
  { name: '首页', path: '/' },
  { name: '归档', path: '/archive' },
  { name: '下载', path: '/download' },
  { name: '关于', path: '/about' },
];
---

<header class="border-b border-slate-200 dark:border-slate-800 sticky top-0 bg-slate-50/95 dark:bg-slate-950/95 backdrop-blur z-50">
  <div class="container-custom">
    <nav class="flex items-center justify-between h-16">
      <a href="/" class="text-xl font-bold text-slate-900 dark:text-slate-100 hover:text-slate-700 dark:hover:text-slate-300">
        My Blog
      </a>

      <ul class="flex items-center gap-6">
        {navItems.map((item) => (
          <li>
            <a
              href={item.path}
              class:list={[
                "text-sm font-medium transition-colors",
                {
                  "text-slate-900 dark:text-slate-100": currentPath === item.path,
                  "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100": currentPath !== item.path,
                },
              ]}
            >
              {item.name}
            </a>
          </li>
        ))}
        <li>
          <button
            id="theme-toggle"
            class="p-2 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-800 transition-colors"
            aria-label="Toggle dark mode"
          >
            <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/>
            </svg>
            <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
            </svg>
          </button>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  });
</script>
