---
interface Props {
  title: string;
  url: string;
  date: string;
  updatedDate?: string;
  author?: string;
  categories?: Array<{ name: string; url: string }>;
  excerpt?: string;
  backgroundImage?: string;
  isPinned?: boolean;
  showFullMeta?: boolean;
}

const {
  title,
  url,
  date,
  updatedDate,
  author = 'Xiting',
  categories = [],
  excerpt,
  backgroundImage,
  isPinned = false,
  showFullMeta = true,
} = Astro.props;
---

<article class="post post-type-normal motion-element" itemscope itemtype="http://schema.org/Article">
  <div class="post-block">
    {isPinned && <div class="pinned-badge">置顶</div>}
    <header class="post-header">
      <h1 class="post-title" itemprop="name headline">
        <a href={url} class="post-title-link" itemprop="url">
          {title}
        </a>
      </h1>

      <div class="post-meta">
        <!-- 第一行：创建日期和修改日期 -->
        <div class="post-meta-row">
          <span class="post-time">
            <span class="post-meta-item-icon">
              <i class="fa-regular fa-calendar"></i>
            </span>
            <time title="创建时间" itemprop="dateCreated datePublished" datetime={date}>
              {date}
            </time>
          </span>

          {updatedDate && (
            <span class="post-updated" style="margin-left: 4px;">
              <span class="post-meta-item-icon">
                <i class="fa-regular fa-calendar-plus"></i>
              </span>
              <time title="修改时间" itemprop="dateModified" datetime={updatedDate}>
                {updatedDate}
              </time>
            </span>
          )}
        </div>

        <!-- 第二行：作者（仅在 showFullMeta 为 true 时显示） -->
        {showFullMeta && (
          <div class="post-meta-row">
            <span class="post-author">
              <span class="post-meta-item-icon">
                <i class="fa-regular fa-pen-to-square"></i>
              </span>
              <span title="作者">作者：{author}</span>
            </span>
          </div>
        )}

        <!-- 第三行：分类（仅在 showFullMeta 为 true 时显示） -->
        {showFullMeta && categories.length > 0 && (
          <div class="post-meta-row">
            <span class="post-category">
              <span class="post-meta-item-icon">
                <i class="fa-regular fa-folder-closed"></i>
              </span>
              {categories.map((cat, index) => (
                <span itemprop="about" itemscope itemtype="http://schema.org/Thing">
                  <a href={cat.url} itemprop="url" rel="index">
                    <span itemprop="name">{cat.name}</span>
                  </a>
                  {index < categories.length - 1 && ', '}
                </span>
              ))}
            </span>
          </div>
        )}
      </div>
    </header>

    {backgroundImage && (
      <div class="post-background" style={`background-image: url('${backgroundImage}')`}></div>
    )}

    {excerpt && (
      <div class="post-body" itemprop="articleBody">
        <div class="post-excerpt" set:html={excerpt} />
      </div>
    )}

    <footer class="post-footer">
      {excerpt && (
        <>
          <div class="post-eof"></div>
          <div class="post-button text-center">
            <a class="btn" href={url} rel="contents">
              阅读全文
            </a>
          </div>
        </>
      )}
    </footer>
  </div>
</article>

<style>
  .post {
    margin: 14px 0;
  }

  .pinned-badge {
    position: absolute;
    top: -1px;
    right: 20px;
    background: #ff5722;
    color: #fff;
    padding: 2px 8px;
    font-size: 12px;
    border-radius: 0 0 4px 4px;
    font-weight: 600;
    z-index: 10;
  }

  .post-block {
    padding: 25px 42px;
    background: #fff;
    border-radius: 0;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
    position: relative;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-header {
    animation: slideDownIn 0.5s ease;
    text-align: center;
  }

  @keyframes slideDownIn {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .post-background {
    width: 100%;
    height: 300px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    margin: 15px 0;
  }

  .post-body {
    animation: slideDownIn 0.5s ease 0.1s both;
    margin-top: 20px;
    color: #555;
    line-height: 1.8;
  }

  .post-title {
    font-size: 26px;
    font-weight: 700;
    margin: 0;
    color: #222;
  }

  .post-title-link {
    color: #222;
    text-decoration: none;
    transition: color 0.3s;
  }

  .post-title-link:hover {
    color: #555;
  }

  .post-meta {
    margin-top: 10px;
    font-size: 13px;
    color: #999;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .post-meta-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-meta-item-icon {
    margin-right: 3px;
  }

  .post-time,
  .post-updated,
  .post-author,
  .post-category {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .post-author a,
  .post-category a {
    color: #999;
    text-decoration: none;
    transition: color 0.3s;
  }

  .post-author a:hover,
  .post-category a:hover {
    color: #222;
  }

  .post-excerpt {
    text-align: left;
    text-indent: 2em;
  }

  .post-button {
    margin-top: 8px;
    margin-bottom: 8px;
  }

  .btn {
    display: inline-block;
    padding: 10px 30px;
    color: #222;
    font-weight: bold;
    text-decoration: underline;
    transition: color 0.3s;
    background: transparent;
  }

  .btn:hover {
    color: #555;
  }

  .post-eof {
    height: 1px;
    margin: 0 0 0 0;
    background: #eee;
  }
</style>
