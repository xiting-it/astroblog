---
import Header from '../components/NextHeader.astro';
import Footer from '../components/NextFooter.astro';
import { loadConfig } from '../lib/config';

interface Props {
  title?: string;
  description?: string;
}

const config = loadConfig();
const { title = config.site.title, description = config.site.description } = Astro.props;
const bgConfig = config.background;
---

<!doctype html>
<html class="theme-next muse use-motion" lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=2" />
    <meta name="theme-color" content="#222" />
    <meta name="description" content={description} />
    <meta name="keywords" content="daliansky,黑果小兵,macOS,Hackintosh,黑苹果,linux,blog.daliansky.net" />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon-next.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon.png" />

    <!-- CSS -->
    <link rel="stylesheet" href="/css/next.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

  </head>

  <body itemscope itemtype="http://schema.org/WebPage" lang="zh-CN">
    <div class="container">
      <Header />

      <!-- 背景图片/视频/播放器 -->
      {bgConfig.mode === 'player' && bgConfig.player.enabled ? (
        <>
          <div id={bgConfig.player.container_id} class="page-background-player"></div>
          <div id="doge-player-config" style="display:none;"
               data-container-id={bgConfig.player.container_id}
               data-user-id={bgConfig.player.user_id}
               data-vcode={bgConfig.player.vcode}
               data-auto-play={bgConfig.player.auto_play}>
          </div>
          <script is:inline>
            if (!window.dogePlayerLoaded) {
              window.dogePlayerLoaded = true;
              const configDiv = document.getElementById('doge-player-config');
              const script = document.createElement('script');
              script.src = 'https://player.dogecloud.com/js/loader';
              script.onload = function() {
                if (typeof DogePlayer !== 'undefined' && configDiv) {
                  new DogePlayer({
                    container: document.getElementById(configDiv.dataset.containerId),
                    userId: parseInt(configDiv.dataset.userId),
                    vcode: configDiv.dataset.vcode,
                    autoPlay: configDiv.dataset.autoPlay === 'true'
                  });
                }
              };
              document.head.appendChild(script);
            }
          </script>
        </>
      ) : bgConfig.mode === 'mp4' && bgConfig.mp4.url ? (
        <video
          id="background-video"
          class="page-background-video"
          autoplay
          loop
          muted
          playsinline
          preload="auto"
          style={`opacity: ${bgConfig.mp4.opacity};`}
          crossorigin="anonymous"
        >
          <source src={bgConfig.mp4.url} type="video/mp4" />
        </video>
      ) : (
        <div
          class="page-background"
          style={`background-image: url('${bgConfig.png.url}'); background-size: ${bgConfig.png.size}; background-position: ${bgConfig.png.position}; background-attachment: ${bgConfig.png.attachment}; opacity: ${bgConfig.png.opacity};`}
        ></div>
      )}

      <main id="main" class="main">
        <div class="main-inner">
          <div class="content-wrap">
            <div id="content" class="content">
              <slot />
            </div>
          </div>
        </div>
      </main>

      <Footer />

      <!-- 返回顶部 -->
      <div class="back-to-top">
        <i class="fa fa-arrow-up"></i>
        <span id="scrollpercent">
          <span>0</span>%
        </span>
      </div>
    </div>

    <!-- Code highlighting - Xcode Light (atom-one-light) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/styles/atom-one-light.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"></script>

    <!-- 代码块复制按钮 -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Apply highlight.js
        if (typeof hljs !== 'undefined') {
          document.querySelectorAll('pre code').forEach((block) => {
            hljs.highlightElement(block);
          });
        }

        // 给每个 pre 添加复制按钮
        document.querySelectorAll('pre').forEach((pre) => {
          // 跳过已添加的
          if (pre.querySelector('.copy-button')) return;

          const button = document.createElement('button');
          button.className = 'copy-button';
          button.textContent = '复制';
          button.setAttribute('aria-label', '复制代码');

          button.addEventListener('click', function() {
            const code = pre.querySelector('code');
            if (!code) return;
            const text = code.textContent;

            navigator.clipboard.writeText(text).then(() => {
              button.textContent = '已复制';
              button.classList.add('copied');
              setTimeout(() => {
                button.textContent = '复制';
                button.classList.remove('copied');
              }, 2000);
            }).catch(() => {
              // fallback
              const textarea = document.createElement('textarea');
              textarea.value = text;
              document.body.appendChild(textarea);
              textarea.select();
              document.execCommand('copy');
              document.body.removeChild(textarea);
              button.textContent = '已复制';
              button.classList.add('copied');
              setTimeout(() => {
                button.textContent = '复制';
                button.classList.remove('copied');
              }, 2000);
            });
          });

          pre.appendChild(button);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
  }

  .container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 10;
  }

  .main {
    flex: 1;
    position: relative;
    z-index: 10;
  }

  .main-inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 20px 20px 40px;
    position: relative;
    z-index: 10;
  }

  /* 确保头部和导航栏在背景图片之上 */
  .header {
    position: relative;
    z-index: 100;
  }

  .site-nav {
    position: relative;
    z-index: 100;
  }

  /* 页脚 */
  .footer {
    position: relative;
    z-index: 100;
  }

  /* 翻页 */
  .pagination {
    position: relative;
    z-index: 100;
  }

  /* 背景图片 - 始终在最底层 */
  .page-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-repeat: no-repeat;
    z-index: 0;
    pointer-events: none;
  }

  /* 背景视频 - 始终在最底层 */
  .page-background-video {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  /* 背景播放器 - 始终在最底层 */
  .page-background-player {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  .page-background-player video,
  .page-background-player iframe,
  .page-background-player .dplayer-video-wrap {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }

  /* 移动端背景图片优化 */
  @media (max-width: 767px) {
    .page-background {
      position: fixed;
      background-size: cover;
      background-position: center top;
    }
  }

  /* 返回顶部按钮 */
  .back-to-top {
    position: fixed;
    bottom: 30px;
    right: 30px;
    width: 40px;
    height: 40px;
    background: #222;
    color: #fff;
    text-align: center;
    line-height: 40px;
    border-radius: 4px;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 1000;
  }

  .back-to-top.back-to-top-on {
    opacity: 1;
  }

  #scrollpercent {
    font-size: 12px;
  }

  /* ===== 代码字体（系统等宽字体）===== */
  code {
    font-family: var(--font-mono);
  }

  /* ===== 行内代码（Starlight 风格）===== */
  p code, li code, td code, th code,
  .post-body code, .post-excerpt code,
  h1 code, h2 code, h3 code, h4 code, h5 code, h6 code {
    color: var(--text-primary) !important;
    background: var(--bg-inline-code);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-size: 0.875em;
    font-family: var(--font-mono);
  }

  /* ===== 代码块（Xcode Light / atom-one-light 风格）===== */
  pre {
    background: #fafafa !important;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md) !important;
    padding: 16px 20px !important;
    overflow-x: auto;
    display: block !important;
    margin: 20px 0;
    position: relative;
  }

  pre code {
    background: transparent !important;
    padding: 0 !important;
    font-size: 14px;
    line-height: 1.6;
    display: block !important;
    font-family: var(--font-mono);
  }
  /* 不用 !important 设置 color，让 atom-one-light 主题的 token 颜色生效 */
  pre code:not(.hljs) {
    color: #383a42;
  }

  /* 复制按钮（右上角，适配浅色背景） */
  pre .copy-button {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 4px 10px;
    background: #fff;
    color: var(--text-muted);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-family: var(--font-sans);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, background 0.2s;
  }

  pre:hover .copy-button {
    opacity: 1;
  }

  pre .copy-button:hover {
    background: var(--color-gray-6);
    color: var(--text-primary);
  }

  pre .copy-button.copied {
    color: var(--color-success);
    border-color: var(--color-success);
  }

  /* 点击水波纹效果 */
  .click-ripple {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    background: radial-gradient(circle, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0) 70%);
    transform: translate(-50%, -50%);
    animation: ripple-expand 0.6s ease-out forwards;
    z-index: 99999;
  }

  @keyframes ripple-expand {
    0% {
      width: 0;
      height: 0;
      opacity: 1;
    }
    100% {
      width: 18px;
      height: 18px;
      opacity: 0;
    }
  }
</style>

    <script is:inline>
      // 动态标题效果
      const originalTitle = document.title;
      let isTabActive = true;

      // 监听页面可见性变化
      document.addEventListener('visibilitychange', function() {
        if (document.hidden) {
          // 标签页失去焦点 - 用户切换到其他标签页
          isTabActive = false;
          document.title = 'zzz睡觉了晚安';
        } else {
          // 标签页获得焦点 - 用户回到这个标签页
          isTabActive = true;
          document.title = '打起精神来ing';
          // 1.5秒后恢复原标题
          setTimeout(function() {
            if (isTabActive) {
              document.title = originalTitle;
            }
          }, 1500);
        }
      });

      // 监听窗口焦点变化（额外保障）
      window.addEventListener('focus', function() {
        if (!isTabActive) {
          isTabActive = true;
          document.title = '打起精神来ing';
          setTimeout(function() {
            if (isTabActive) {
              document.title = originalTitle;
            }
          }, 1500);
        }
      });

      window.addEventListener('blur', function() {
        if (!document.hidden) {
          // 某些情况下 blur 会触发但 hidden 为 false
          isTabActive = false;
          document.title = 'zzz睡觉了晚安';
        }
      });
    </script>

<script is:inline>
      // Back to top functionality
      document.addEventListener('DOMContentLoaded', function() {
        const backToTop = document.querySelector('.back-to-top');
        const scrollpercent = document.querySelector('#scrollpercent span');

        window.addEventListener('scroll', function() {
          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
          const scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
          const scrollPercent = Math.round((scrollTop / scrollHeight) * 100);

          if (scrollpercent) {
            scrollpercent.textContent = scrollPercent;
          }

          if (scrollTop > 300) {
            backToTop?.classList.add('back-to-top-on');
          } else {
            backToTop?.classList.remove('back-to-top-on');
          }
        });

        backToTop?.addEventListener('click', function() {
          window.scrollTo({
            top: 0,
            behavior: 'smooth'
          });
        });

        // 确保背景视频自动播放
        const backgroundVideo = document.getElementById('background-video');
        if (backgroundVideo) {
          let playAttemptCount = 0;
          const maxPlayAttempts = 3;

          // 尝试播放视频
          const playVideo = () => {
            if (playAttemptCount >= maxPlayAttempts) {
              console.log('达到最大播放尝试次数');
              return;
            }

            playAttemptCount++;

            backgroundVideo.play().then(() => {
              console.log('背景视频开始播放');
              // 播放成功，设置较低的播放速率以避免卡顿
              if (backgroundVideo.playbackRate > 1.0) {
                backgroundVideo.playbackRate = 1.0;
              }
            }).catch(error => {
              console.log('自动播放被阻止，尝试其他方法:', error);
              // 如果自动播放被阻止，添加点击监听器
              if (playAttemptCount === 1) {
                document.addEventListener('click', function playOnClick() {
                  backgroundVideo.play();
                  document.removeEventListener('click', playOnClick);
                }, { once: true });
              }
            });
          };

          // 监听视频加载状态
          backgroundVideo.addEventListener('loadeddata', () => {
            console.log('视频数据已加载');
            // 视频数据加载完成后尝试播放
            playVideo();
          });

          backgroundVideo.addEventListener('canplay', () => {
            console.log('视频可以播放');
          });

          backgroundVideo.addEventListener('canplaythrough', () => {
            console.log('视频可以流畅播放');
          });

          // 监听播放进度，防止卡顿
          backgroundVideo.addEventListener('progress', () => {
            // 视频正在加载
          });

          // 监听播放速率
          backgroundVideo.addEventListener('ratechange', () => {
            console.log('播放速率:', backgroundVideo.playbackRate);
          });

          // 监听视频状态
          backgroundVideo.addEventListener('suspend', () => {
            console.log('视频加载被挂起');
            // 视频加载被挂起，再次尝试播放
            playVideo();
          });

          backgroundVideo.addEventListener('stalled', () => {
            console.log('视频加载停滞');
          });

          backgroundVideo.addEventListener('waiting', () => {
            console.log('视频等待数据');
          });

          backgroundVideo.addEventListener('ended', () => {
            // 视频播放结束，重新开始（虽然有loop属性，但为了保险）
            console.log('视频播放结束，重新开始');
            backgroundVideo.currentTime = 0;
            backgroundVideo.play();
          });

          // 页面加载完成后立即尝试播放
          if (backgroundVideo.readyState >= 2) {
            // 视频已经有足够的数据
            playVideo();
          }
        }
      });
    </script>

    <!-- 水波纹和心电图效果 -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // ========== 水波纹点击效果 ==========
        function createRipple(e) {
          const ripple = document.createElement('div');
          ripple.className = 'click-ripple';

          // 获取点击位置
          const x = e.clientX;
          const y = e.clientY;

          ripple.style.left = x + 'px';
          ripple.style.top = y + 'px';

          document.body.appendChild(ripple);

          // 动画结束后移除元素
          setTimeout(() => {
            ripple.remove();
          }, 600);
        }

        // 监听所有鼠标点击事件（左键和右键）
        document.addEventListener('mousedown', function(e) {
          // 只在主点击（左键0或右键2）时触发
          if (e.button === 0 || e.button === 2) {
            createRipple(e);
          }
        });
      });
    </script>
